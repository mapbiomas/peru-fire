graph TD
    %% Configuração de Alto Contraste (Fundo Pastel + Texto Ultra Escuro)
    classDef ui fill:#E1F5FE,stroke:#0288D1,stroke-width:1.5px,color:#01579B;
    classDef fila fill:#F3E5F5,stroke:#7B1FA2,stroke-width:1.5px,color:#4A148C;
    classDef process fill:#FFF3E0,stroke:#F57C00,stroke-width:1.5px,color:#5D2500;
    classDef storage fill:#E8F5E9,stroke:#388E3C,stroke-width:1.5px,color:#0B3C11;
    classDef decision fill:#FCE4EC,stroke:#C2185B,stroke-width:1.5px,color:#5A0426;
    classDef note fill:#FFFDE7,stroke:#FBC02D,stroke-width:1.2px,stroke-dasharray: 4 4,color:#6D4C41;

    %% ==========================================
    %% QUADRO 1: INTERFACE E FILA (Canto Superior Esquerdo)
    %% ==========================================
    subgraph QUADRO_UI ["QUADRO 1: Interface & Entrada de Dados"]
        direction TB
        A[Configuração Lote:<br>Modelo x Região x Período] -->|Añadir Lote| B(Fila JSON Local<br>Status: PENDING)
        Aba[Abas UI:<br>Gerenciar / Filtrar Jobs] -.-> B
    end
    class QUADRO_UI,A,Aba ui; class B fila;

    %% ==========================================
    %% QUADRO 2: FASE 1 - PROCESSAMENTO (Canto Superior Direito)
    %% ==========================================
    subgraph QUADRO_FASE1 ["QUADRO 2: Fase 1 - Classificação Regional"]
        direction TB
        C[Motor lê Fila:<br>PENDING & enabled] --> D{Mosaico em<br>GCS?}
        D -- Sim --> D_Sim[Ignora Job]
        D -- Não --> E[Status: RUNNING]
        
        E --> F[Carrega Modelo .npz<br>& Grid GEE]
        F --> G{Tile existe<br>no GCS?}
        
        G -- Sim --> H[Pula: Checkpoint]
        G -- Não --> I[Classifica:<br>COG + DNN] --> J[Upload Tile para GCS]
        
        H --> K{Fim do<br>Grid?}
        J --> K
        
        K -- Não --> F
        K -- Sim --> L(Status: COMPLETED)
    end
    class QUADRO_FASE1,C,E,F,I,J,L process; class D,G,K decision; class D_Sim,H note;

    %% ==========================================
    %% QUADRO 3: FASE 2 - INTEGRAÇÃO GEE (Canto Inferior Esquerdo)
    %% ==========================================
    subgraph QUADRO_FASE2 ["QUADRO 3: Fase 2 - Upload GEE"]
        direction TB
        M[Fila: Jobs COMPLETED] --> N{upload_gee<br>is True?}
        N -- Não --> O[Fim do Fluxo]
        N -- Sim --> P[Merge local dos<br>tiles do GCS]
        P --> Q[Upload Mosaico para GCS]
        Q --> R[Dispara Task GEE:<br>Export.image.toAsset]
    end
    class QUADRO_FASE2,M,P,Q,R process; class N decision; class O note;

    %% ==========================================
    %% QUADRO 4: ECOSSISTEMA DE DADOS (Canto Inferior Direito)
    %% ==========================================
    subgraph QUADRO_DADOS ["QUADRO 4: Repositório de Dados"]
        direction LR
        subgraph GCS_Data ["Diretórios GCS"]
            m_in[library_models/]
            t_out[classified_tiles/]
            m_out[regional_mosaics/]
        end
        subgraph GEE_Data ["Ativos GEE"]
            g_in[Grid/Limites]
            g_out[ImageCollection]
        end
    end
    class QUADRO_DADOS,GCS_Data,GEE_Data,m_in,t_out,m_out,g_in,g_out storage;

    %% ==========================================
    %% CONEXÕES E FLUXO ENTRE OS QUADROS
    %% ==========================================
    
    %% Fluxo lógico principal (Mosaico)
    B ====>|1. Dispara Execução| C
    L ====>|2. Transfere Concluídos| M

    %% Conexões de Leitura e Escrita mapeadas para o Quadro de Dados
    F -.->|Lê Pesos| m_in
    F -.->|Consulta| g_in
    G -.->|Valida| t_out
    J -.->|Grava| t_out
    P -.->|Lê Tiles| t_out
    Q -.->|Grava Mosaico| m_out
    R -.->|Registra Asset| g_out    